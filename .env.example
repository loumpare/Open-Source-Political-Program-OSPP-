# ── OSPP — Configuration ──────────────────────────────────────────────────────
# Copier ce fichier en .env et ajuster les valeurs

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
# Options : qwen2.5:7b (défaut, ~4.7 GB) | llama3.2:3b (~2 GB, plus léger)
OLLAMA_MODEL=qwen2.5:7b

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules). Ne jamais mettre * en prod.
# En local Docker : laisser vide (nginx gère le proxy, pas de CORS nécessaire)
# Si exposé publiquement : mettre votre domaine, ex: https://ospp.mondomaine.com
CORS_ORIGINS=http://localhost:3000,http://localhost:4173

# ── Déploiement ───────────────────────────────────────────────────────────────
# Port exposé par le frontend (défaut : 80)
PORT=80
