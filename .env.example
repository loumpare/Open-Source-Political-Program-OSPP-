# ── OSPP — Configuration ──────────────────────────────────────────────────────
# Copier ce fichier en .env et ajuster les valeurs

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL du serveur Ollama (modifiable si Ollama tourne hors Docker)
OLLAMA_URL=http://ollama:11434

# Modèle LLM à utiliser (doit être pull-é dans le conteneur ollama)
# Options : qwen2.5:7b (défaut, ~4.7 GB) | llama3.2:3b (~2 GB, plus léger)
OLLAMA_MODEL=qwen2.5:7b

# ── Frontend ──────────────────────────────────────────────────────────────────
# En développement local (.env.local) :
# VITE_API_URL=http://127.0.0.1:8001
# En Docker : /api (proxy nginx) — déjà géré par docker-compose.yml

# ── Déploiement ───────────────────────────────────────────────────────────────
# Port exposé par le frontend (défaut : 80)
PORT=80
