# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL
POSTGRES_USER=ospp
POSTGRES_PASSWORD=ospp_dev                  # change in production
POSTGRES_DB=ospp
DATABASE_URL=postgresql://ospp:ospp_dev@db:5432/ospp

# Redis — MUST set a strong password in production
REDIS_PASSWORD=changeme_redis               # change in production
REDIS_URL=redis://:changeme_redis@redis:6379/0

# Backend
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_in_production           # REQUIRED in production — app refuses to start if unchanged
DEBUG=true                                  # set to false in production — hides /docs and stack traces
CORS_ORIGINS=http://localhost:3000          # comma-separated; never use * in production

# Frontend
VITE_API_URL=http://localhost:8000
